INT32 x;
GET x;
PRINT x;

INT32 y[1];
GET y[0];
PRINT y[0];

INT32 z = x * y[0];
PRINT z;

INT8 v8;
INT16 v16;
INT64 v64;
FLOAT32 f32;
FLOAT64 f64;

GET v8;
GET v16;
GET v64;
GET f32;
GET f64;

PRINT v8;
PRINT v16;
PRINT v64;
PRINT f32;
PRINT f64;
