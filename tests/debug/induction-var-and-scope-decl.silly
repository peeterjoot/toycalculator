// Check that myLoopVar has correct debug info
// RUN: %ExeSilly -g %s -o %t.exe
// RUN: dwarfdump %t.exe > %t.dd
// RUN: %t.exe | %FileCheck %s --check-prefix=EXEC
// RUN: %FileCheck %s --input-file=%t.dd
// EXEC: 1
// EXEC-NEXT: 4
// EXEC-NEXT: 2
// EXEC-NEXT: 5
// EXEC-NEXT: 3
// EXEC-NEXT: 6
// EXEC-NEXT: 4
// EXEC-NEXT: 7
// CHECK: DW_AT_name{{[[:space:]]+}}myLoopVar
// CHECK: DW_AT_decl_file{{.*}}induction-var-and-scope-decl.silly
// CHECK: DW_AT_decl_line{{[[:space:]]+}}0x00000016
// CHECK: DW_AT_name{{[[:space:]]+}}myScopeVar
// CHECK: DW_AT_decl_file{{.*}}induction-var-and-scope-decl.silly
// CHECK: DW_AT_decl_line{{[[:space:]]+}}0x00000018


FOR (INT64 myLoopVar : (1, 5)) // line 22
{
    INT64 myScopeVar; // line 24
    PRINT myLoopVar;
    myScopeVar = 3 + myLoopVar;
    PRINT myScopeVar;
};
