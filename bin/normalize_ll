#!/usr/bin/perl

#-----------------------------------------------------------------------------
# POD Format Documentation.  Read "perldoc perlpod" for an example.
# When done, check syntax with "podchecker".

=head1 NAME

normalize_ll - <one-line-description>

=head1 SYNOPSIS

normalize_ll [--help] [<options>]

=head1 DESCRIPTION

A perl script that normalizes some types of LLVM-IR, and normalizes it for comparision.

=head1 SUPPORTED PLATFORMS

 Unix (Linux verified)

=head1 SUPPORT

 Send email to peeterjoot@pm.me

=head1 AUTHORS

 Peeter Joot

=cut

#-----------------------------------------------------------------------------

use strict ;
use warnings ;
use Getopt::Long ;
use Pod::Usage ;

# Suppress sourcing of users' .bashrc files in invoked shells
delete $ENV{'ENV'} ;
delete $ENV{'BASH_ENV'} ;

# Set STDOUT and STDERR to unbuffered
select STDERR ; $| = 1 ;
select STDOUT ; $| = 1 ;

my $myName = '' ;

($myName = $0) =~ s@.*[/\\]@@ ;

#Getopt::Long::Configure( 'pass_through' ) ;
GetOptions (
   'help'               => sub { pod2usage(-verbose => 2) ; },
) or pod2usage(-verbose => 0) ;

# Validate/handle options, and everything else...

# Read entire file
my $content = do { local $/; <STDIN> };

# Split into code section and metadata section
my $in_meta = 0;
my @meta_lines;
my @code_lines;

for my $line (split /\n/, $content) {
    if (!$in_meta && $line =~ /^!/) {
        $in_meta = 1;
    }
    if ($in_meta) {
        push @meta_lines, $line;
    } else {
        push @code_lines, $line;
    }
}

# Parse metadata nodes into a hash: number -> full definition
my %meta_def;
for my $line (@meta_lines) {
    if ($line =~ /^!(\d+)\s*=\s*(.*)$/) {
        $meta_def{$1} = $2;
    }
}

# Assign names - single pass in numeric order so references are stable
my %name;
my $lex_counter  = 0;
my $loc_counter  = 0;
my $scope_index  = 0;  # monotonic integer for scopes (subprogram + lexical blocks)
my %scope_num;         # num -> scope integer (for use in diloc names)

# First pass: assign scope integers to subprograms and lexical blocks,
# and simple names to files, CUs, etc.
for my $num (sort { $a <=> $b } keys %meta_def) {
    my $def = $meta_def{$num};

    if ($def =~ /!DIFile\(/) {
        $name{$num} = "difile";
    }
    elsif ($def =~ /!DICompileUnit\(/) {
        $name{$num} = "dicu";
    }
    elsif ($def =~ /!DISubprogram\(.*?name:\s*"([^"]+)"/) {
        my $fname = $1;
        $scope_num{$num} = $scope_index++;
        $name{$num} = "disub_${fname}_s$scope_num{$num}";
    }
    elsif ($def =~ /!DILexicalBlock\(/) {
        $scope_num{$num} = $scope_index++;
        $name{$num} = "dilex_$lex_counter";
        $lex_counter++;
    }
    elsif ($def =~ /!DILocalVariable\(name:\s*"([^"]+)"/) {
        $name{$num} = "divar_$1";
    }
    elsif ($def =~ /!DIBasicType\(name:\s*"([^"]+)"/) {
        my $tname = $1;
        $tname =~ s/\s+/_/g;
        $name{$num} = "dibasic_$tname";
    }
    elsif ($def =~ /!DISubroutineType\(/) {
        $name{$num} = "disubrty";
    }
    elsif ($def =~ /!DIGlobalVariableExpression\(/) {
        $name{$num} = "diglobexpr_$num";
    }
    elsif ($def =~ /!DIGlobalVariable\(/) {
        $name{$num} = "diglobvar_$num";
    }
    elsif ($def =~ /!DICompositeType\(/) {
        $name{$num} = "dicompty_$num";
    }
    elsif ($def =~ /!DISubrange\(/) {
        $name{$num} = "disubrange_$num";
    }
    elsif ($def =~ /!DIDerivedType\(/) {
        $name{$num} = "diderivedty_$num";
    }
    elsif ($def =~ /^!\{/ ) { #|| $def =~ /^!{/) {
        $name{$num} = "dimlist_$num";
    }
    else {
        $name{$num} = "dimeta_$num";
    }
}

# Second pass: assign DILocation names now that all scope integers are known
for my $num (sort { $a <=> $b } keys %meta_def) {
    my $def = $meta_def{$num};
    if ($def =~ /!DILocation\(line:\s*(\d+),\s*column:\s*(\d+),\s*scope:\s*!(\d+)/) {
        my ($line, $col, $scope_num) = ($1, $2, $3);
        my $sidx = exists $scope_num{$scope_num} ? $scope_num{$scope_num} : "?";
        $name{$num} = "diloc_${line}_${col}_s${sidx}";
    }
}

# Substitute !N -> !name everywhere in a string
sub subst {
    my ($str) = @_;
    $str =~ s/!(\d+)\b/exists $name{$1} ? "!$name{$1}" : "!$1"/ge;
    return $str;
}

# Output substituted code section
print join("\n", map { subst($_) } @code_lines), "\n";

# Output substituted metadata section with new lhs names
for my $line (@meta_lines) {
    if ($line =~ /^!(\d+)\s*=\s*(.*)$/) {
        my ($num, $def) = ($1, $2);
        my $new_lhs = "!" . ($name{$num} // $num);
        my $new_def = subst($def);
        print "$new_lhs = $new_def\n";
    } else {
        print subst($line), "\n";
    }
}

# vim: et ts=4 sw=4
